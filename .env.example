# ============================================
# StoryForge AI - Environment Variables
# ============================================

# Server
PORT=3000
NODE_ENV=production

# MongoDB (use Atlas or local)
# MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/storyforge
MONGODB_URI=

# JWT Secret (change this!)
JWT_SECRET=storyforge_change_this_secret_key_2024

# LLM Providers (set at least one)
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1

# Anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# DeepSeek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Custom LLM
CUSTOM_LLM_URL=
CUSTOM_LLM_KEY=
CUSTOM_LLM_MODEL=

# Logging
LOG_LEVEL=info

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=300
